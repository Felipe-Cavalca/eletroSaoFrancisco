{
  "name": "eletroSaoFrancisco-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "overrideCommand": false,
  "runArgs": [
    "--name",
    "eletro-sao-francisco-dev"
  ],
  "appPort": [
    "8080:8080"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "mhutchie.git-graph"
      ]
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "GitHub Pages preview",
      "protocol": "http",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "root"
}
